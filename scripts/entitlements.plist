<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime is required for notarization. Flusso is NOT sandboxed
         (it needs to paste into other apps and watch the Fn key globally),
         so we do not add App Sandbox entitlements. -->

    <!-- Microphone access under the hardened runtime. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- If notarization or model loading ever fails with a library-validation
         error from FluidAudio or CoreML, uncomment the next line and re-sign.
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    -->
</dict>
</plist>
